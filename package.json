{
  "name": "shortyq",
  "version": "2.1.0",
  "description": "A quantum-safe URL shortener using NIST-standardized post-quantum cryptography (ML-KEM-768)",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "shortyq": "dist/cli.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "clean": "rimraf dist coverage",
    "bench": "ts-node benchmarks/compare.ts",
    "prepare": "npm run clean && npm run build",
    "prepublishOnly": "npm test",
    "preversion": "npm run test",
    "version": "git add -A src"
  },
  "keywords": [
    "url-shortener",
    "post-quantum",
    "quantum-safe",
    "ml-kem",
    "kyber",
    "encryption",
    "typescript",
    "secure",
    "url",
    "shortener",
    "crypto"
  ],
  "author": {
    "name": "Ayush Jadaun",
    "email": "ayushjadaun6@gmail.com",
    "url": "https://github.com/ayush-jadaun"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ayush-jadaun/ShortyQ.git"
  },
  "bugs": {
    "url": "https://github.com/ayush-jadaun/ShortyQ/issues"
  },
  "homepage": "https://github.com/ayush-jadaun/ShortyQ#readme",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@noble/ciphers": "^1.3.0",
    "@noble/curves": "^1.9.7",
    "@noble/hashes": "^1.8.0",
    "@noble/post-quantum": "^0.4.1",
    "nanoid": "^3.3.4"
  },
  "devDependencies": {
    "@types/jest": "^29.5.12",
    "@types/node": "^20.11.24",
    "jest": "^29.7.0",
    "rimraf": "^6.0.1",
    "shortyq-v1": "npm:shortyq@^1.0.1",
    "ts-jest": "^29.1.2",
    "ts-node": "^10.9.2",
    "tweetnacl": "^1.0.3",
    "typescript": "^5.3.3"
  }
}
